# =====================================================================
# REQUIRED — the only variable needed to run the app
# =====================================================================
# PostgreSQL connection string (Neon or any PostgreSQL provider)
# For Neon: use the "pooled" connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# =====================================================================
# OPTIONAL — only needed when running "npx prisma migrate deploy"
# Neon requires a direct/non-pooled connection for migrations.
# Not read by the running application at all.
# =====================================================================
# DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# =====================================================================
# REQUIRED for AI-powered NL task parsing — POST /api/ai/parse
# Obtain your key at https://console.anthropic.com/
# =====================================================================
ANTHROPIC_API_KEY="sk-ant-..."
