# =====================================================================
# REQUIRED — the only variable needed to run the app
# =====================================================================
# PostgreSQL connection string (Neon or any PostgreSQL provider)
# For Neon: use the "pooled" connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# =====================================================================
# OPTIONAL — only needed when running "npx prisma migrate deploy"
# Neon requires a direct/non-pooled connection for migrations.
# Not read by the running application at all.
# =====================================================================
# DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# =====================================================================
# REQUIRED for AI-powered NL task parsing — POST /api/ai/parse
# Obtain your key at https://console.anthropic.com/
# =====================================================================
ANTHROPIC_API_KEY="sk-ant-..."

# =====================================================================
# REQUIRED for the cron deadline-check endpoint — GET /api/cron/deadline-check
# Generate with: openssl rand -hex 32
# Without this set, the endpoint rejects all requests (fail-closed).
# =====================================================================
CRON_SECRET="your-random-secret-here"

# =====================================================================
# OPTIONAL — how often the deadline-check cron actually runs, in hours.
# Determines the reminder window so thresholds tile without gaps.
# Vercel Hobby runs daily -> leave unset (defaults to 24).
# Vercel Pro with schedule "0 * * * *" -> set to 1 for precise reminders.
# =====================================================================
# CRON_INTERVAL_HOURS="24"

# =====================================================================
# OPTIONAL — Telegram bot integration
# 1. Create a bot via @BotFather, copy the token
# 2. Set the bot username (without @)
# 3. Register webhook: POST https://api.telegram.org/bot<TOKEN>/setWebhook
#    with { "url": "https://yourdomain.com/api/telegram/webhook",
#           "secret_token": "<TELEGRAM_WEBHOOK_SECRET>" }
# =====================================================================
TELEGRAM_BOT_TOKEN="123456789:AAF..."
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME="your_bot_name_bot"
# Optional but recommended: webhook secret to verify requests from Telegram
TELEGRAM_WEBHOOK_SECRET="generate-with-openssl-rand-hex-32"
