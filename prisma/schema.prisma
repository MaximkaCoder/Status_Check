generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Status {
  TO_CHECK
  EXPIRED
  DONE
  NOT_ACTUAL
  IDEAS_BACKLOG
}

model Project {
  id          String          @id @default(cuid())
  name        String          @unique
  description String?
  members     ProjectMember[]
  files       ProjectFile[]
  created_at  DateTime        @default(now()) @map("created_at")

  @@map("projects")
}

model ProjectMember {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

model ProjectFile {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name       String
  url        String
  size       Int
  created_at DateTime @default(now()) @map("created_at")

  @@map("project_files")
}

model User {
  id             String         @id @default(cuid())
  name           String         @unique
  email          String         @unique
  password       String
  isAdmin        Boolean        @default(false)
  blocked        Boolean        @default(false)
  resetCodeHash    String?      @map("reset_code_hash")
  resetCodeExpires DateTime?    @map("reset_code_expires")
  resetAttempts    Int          @default(0) @map("reset_attempts")
  departmentId   String?
  department     Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  created_at     DateTime       @default(now()) @map("created_at")
  notifications   Notification[]
  projectMembers  ProjectMember[]
  comments        Comment[]
  settings        UserSettings?
  assignedItems   StatusItem[]  @relation("AssignedItems")
  reviewedItems   StatusItem[]  @relation("ReviewedItems")

  @@index([departmentId])
  @@map("users")
}

model UserSettings {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  telegramChatId  String?
  telegramToken   String?
  notifyVia       String[] @default(["app"])
  notifyOnAssign  Boolean  @default(true)
  notifyOnComment Boolean  @default(true)
  notifyOnStatus  Boolean  @default(true)
  deadlineHours   Int[]    @default([24])
  updated_at      DateTime @updatedAt @map("updated_at")

  @@map("user_settings")
}

model Department {
  id         String   @id @default(cuid())
  name       String   @unique
  users      User[]
  created_at DateTime @default(now()) @map("created_at")

  @@map("departments")
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum NotificationType {
  ASSIGNED_ASSIGNEE
  ASSIGNED_REVIEWER
  NEW_COMMENT
  STATUS_CHANGED
  DEADLINE_APPROACHING
  MENTIONED
}

model Notification {
  id             String           @id @default(cuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           NotificationType
  itemId         String
  itemTitle      String
  read           Boolean          @default(false)
  thresholdHours Int?
  created_at     DateTime         @default(now()) @map("created_at")

  @@index([userId, read])
  @@index([userId, created_at])
  @@map("notifications")
}

model StatusItem {
  id           String     @id @default(cuid())
  title        String
  description  String?
  deadline     DateTime?
  status       Status     @default(TO_CHECK)
  creator_name String
  creator_id   String?  @map("creator_id")
  project      String?
  assignee     String?
  reviewer     String?
  assigneeId   String?  @map("assignee_id")
  reviewerId   String?  @map("reviewer_id")
  assigneeUser User?    @relation("AssignedItems", fields: [assigneeId], references: [id], onDelete: SetNull)
  reviewerUser User?    @relation("ReviewedItems", fields: [reviewerId], references: [id], onDelete: SetNull)
  department   String?
  priority     Priority   @default(MEDIUM)
  done_at      DateTime?  @map("done_at")
  done_by      String?    @map("done_by")
  deleted_at   DateTime?  @map("deleted_at")
  created_at   DateTime   @default(now()) @map("created_at")
  updated_at   DateTime   @updatedAt @map("updated_at")
  files        ItemFile[]
  comments     Comment[]
  subtasks     Subtask[]

  @@index([deadline])
  @@index([status])
  @@index([deadline, status])
  @@index([created_at])
  @@index([assigneeId])
  @@index([reviewerId])
  @@index([deleted_at])
  @@map("status_items")
}

model Subtask {
  id         String     @id @default(cuid())
  itemId     String
  item       StatusItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  title      String
  done       Boolean    @default(false)
  order      Int        @default(0)
  created_at DateTime   @default(now()) @map("created_at")

  @@index([itemId, order])
  @@map("subtasks")
}

model ItemFile {
  id         String     @id @default(cuid())
  itemId     String
  item       StatusItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  name       String
  url        String
  size       Int
  created_at DateTime   @default(now()) @map("created_at")

  @@map("item_files")
}

model Comment {
  id         String     @id @default(cuid())
  itemId     String
  item       StatusItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  authorId   String
  author     User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorName String
  text       String     @db.Text
  created_at DateTime   @default(now()) @map("created_at")

  @@index([itemId, created_at])
  @@map("comments")
}

model ItemCommentSeen {
  itemId String
  userId String
  seenAt DateTime @map("seen_at")

  @@id([itemId, userId])
  @@map("item_comment_seen")
}

model ItemActivity {
  id         String   @id @default(cuid())
  itemId     String
  userId     String?
  userName   String
  action     String   // CREATED | STATUS_CHANGED | FIELD_CHANGED
  field      String?  // status | assignee | reviewer | deadline | priority | title | description | project
  oldValue   String?
  newValue   String?
  created_at DateTime @default(now()) @map("created_at")

  @@index([itemId, created_at])
  @@map("item_activity")
}
