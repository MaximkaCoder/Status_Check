generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Status {
  TO_CHECK
  EXPIRED
  DONE
  NOT_ACTUAL
  IDEAS_BACKLOG
}

model Project {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  created_at  DateTime @default(now()) @map("created_at")

  @@map("projects")
}

model User {
  id             String         @id @default(cuid())
  name           String
  email          String         @unique
  password       String
  isAdmin        Boolean        @default(false)
  blocked        Boolean        @default(false)
  departmentId   String?
  department     Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  created_at     DateTime       @default(now()) @map("created_at")
  notifications  Notification[]

  @@index([departmentId])
  @@map("users")
}

model Department {
  id         String   @id @default(cuid())
  name       String   @unique
  users      User[]
  created_at DateTime @default(now()) @map("created_at")

  @@map("departments")
}

enum NotificationType {
  ASSIGNED_ASSIGNEE
  ASSIGNED_REVIEWER
}

model Notification {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       NotificationType
  itemId     String
  itemTitle  String
  read       Boolean          @default(false)
  created_at DateTime         @default(now()) @map("created_at")

  @@index([userId, read])
  @@index([userId, created_at])
  @@map("notifications")
}

model StatusItem {
  id           String    @id @default(cuid())
  title        String
  description  String?
  deadline     DateTime?
  status       Status    @default(TO_CHECK)
  creator_name String
  project      String?
  assignee     String?
  reviewer     String?
  created_at   DateTime  @default(now()) @map("created_at")
  updated_at   DateTime  @updatedAt @map("updated_at")

  @@index([deadline])
  @@index([status])
  @@index([deadline, status])
  @@index([created_at])
  @@map("status_items")
}
