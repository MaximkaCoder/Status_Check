generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Status {
  TO_CHECK
  EXPIRED
  DONE
  NOT_ACTUAL
  IDEAS_BACKLOG
}

model Project {
  id         String   @id @default(cuid())
  name       String   @unique
  created_at DateTime @default(now()) @map("created_at")

  @@map("projects")
}

model User {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  password   String
  isAdmin    Boolean  @default(false)
  created_at DateTime @default(now()) @map("created_at")

  @@map("users")
}

model StatusItem {
  id           String    @id @default(cuid())
  title        String
  description  String?
  deadline     DateTime?
  status       Status    @default(TO_CHECK)
  creator_name String
  project      String?
  assignee     String?
  reviewer     String?
  created_at   DateTime  @default(now()) @map("created_at")
  updated_at   DateTime  @updatedAt @map("updated_at")

  @@index([deadline])
  @@index([status])
  @@index([deadline, status])
  @@index([created_at])
  @@map("status_items")
}
