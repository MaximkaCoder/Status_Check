generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Status {
  TO_CHECK
  EXPIRED
  DONE
  NOT_ACTUAL
  IDEAS_BACKLOG
}

model Project {
  id          String          @id @default(cuid())
  name        String          @unique
  description String?
  members     ProjectMember[]
  files       ProjectFile[]
  created_at  DateTime        @default(now()) @map("created_at")

  @@map("projects")
}

model ProjectMember {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

model ProjectFile {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name       String
  url        String
  size       Int
  created_at DateTime @default(now()) @map("created_at")

  @@map("project_files")
}

model User {
  id             String         @id @default(cuid())
  name           String
  email          String         @unique
  password       String
  isAdmin        Boolean        @default(false)
  blocked        Boolean        @default(false)
  departmentId   String?
  department     Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  created_at     DateTime       @default(now()) @map("created_at")
  notifications   Notification[]
  projectMembers  ProjectMember[]
  comments        Comment[]

  @@index([departmentId])
  @@map("users")
}

model Department {
  id         String   @id @default(cuid())
  name       String   @unique
  users      User[]
  created_at DateTime @default(now()) @map("created_at")

  @@map("departments")
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum NotificationType {
  ASSIGNED_ASSIGNEE
  ASSIGNED_REVIEWER
  NEW_COMMENT
  STATUS_CHANGED
  DEADLINE_APPROACHING
}

model Notification {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       NotificationType
  itemId     String
  itemTitle  String
  read       Boolean          @default(false)
  created_at DateTime         @default(now()) @map("created_at")

  @@index([userId, read])
  @@index([userId, created_at])
  @@map("notifications")
}

model StatusItem {
  id           String     @id @default(cuid())
  title        String
  description  String?
  deadline     DateTime?
  status       Status     @default(TO_CHECK)
  creator_name String
  project      String?
  assignee     String?
  reviewer     String?
  department   String?
  priority     Priority   @default(MEDIUM)
  done_at      DateTime?  @map("done_at")
  done_by      String?    @map("done_by")
  created_at   DateTime   @default(now()) @map("created_at")
  updated_at   DateTime   @updatedAt @map("updated_at")
  files        ItemFile[]
  comments     Comment[]

  @@index([deadline])
  @@index([status])
  @@index([deadline, status])
  @@index([created_at])
  @@map("status_items")
}

model ItemFile {
  id         String     @id @default(cuid())
  itemId     String
  item       StatusItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  name       String
  url        String
  size       Int
  created_at DateTime   @default(now()) @map("created_at")

  @@map("item_files")
}

model Comment {
  id         String     @id @default(cuid())
  itemId     String
  item       StatusItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  authorId   String
  author     User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorName String
  text       String     @db.Text
  created_at DateTime   @default(now()) @map("created_at")

  @@index([itemId, created_at])
  @@map("comments")
}

model ItemCommentSeen {
  itemId String
  userId String
  seenAt DateTime @map("seen_at")

  @@id([itemId, userId])
  @@map("item_comment_seen")
}
